{
  "name": "mini-agent",
  "version": "1.0.0",
  "description": "最小可用的AI Agent CLI工具，基于Node.js、TypeScript和LangChain",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mini-agent": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc && node dist/index.js",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"./**/*.{ts,tsx,js,jsx,mjs,cjs}\"",
    "lint:fix": "eslint \"./**/*.{ts,tsx,js,jsx,mjs,cjs}\" --fix",
    "format": "prettier --write \"./**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,less,css}\"",
    "format:check": "prettier --check \"./**/*.{ts,tsx,js,jsx,mjs,cjs,json,md,less,css}\"",
    "prepare": "husky"
  },
  "keywords": [
    "ai",
    "agent",
    "langchain",
    "cli",
    "typescript"
  ],
  "author": "Claude Code",
  "license": "MIT",
  "dependencies": {
    "@langchain/core": "^1.1.28",
    "@langchain/openai": "^1.2.10",
    "@langchain/tavily": "^1.2.0",
    "@supabase/supabase-js": "^2.45.0",
    "chalk": "^5.3.0",
    "cli-boxes": "^3.0.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "ora": "^8.1.1",
    "wrap-ansi": "^9.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{less,css}": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^9.39.3",
    "@types/node": "^25.3.1",
    "@types/wrap-ansi": "^8.1.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.39.3",
    "eslint-config-google": "^0.14.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^3.0.0"
  },
  "optionalDependencies": {
    "@esbuild/darwin-arm64": "^0.27.3",
    "@rollup/rollup-darwin-arm64": "^4.59.0"
  }
}
