# 配置文件示例
# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_API_KEY=your-supabase-anon-key

# Embedding API Configuration
EMBEDDING_API_KEY=your-dashscope-api-key

# 模型基础URL
MODEL_BASE_URL=https://api.openai.com/v1

# 模型名称
MODEL_NAME=gpt-3.5-turbo

# API密钥 (OpenAI或其他提供商)
MODEL_API_KEY=your-api-key

# 温度参数 (0-2, 默认0.7)
MODEL_TEMPERATURE=0.7

# 最大token数量 (默认2048)
MODEL_MAX_TOKENS=2048

# ========== 工具配置 (插件化) ==========
# 默认加载所有 tools/plugins 目录下的工具
# 可通过 DISABLED_TOOLS 禁用指定工具，逗号分隔
# 例如: DISABLED_TOOLS=tavily,chrome

# 工具专属配置
TAVILY_API_KEY=your-tavily-api-key

# ========== 编排层配置 (Orchestration Layer) ==========
# 最大迭代次数 (默认: 3)
ORCHESTRATION_MAX_ITERATIONS=3

# 执行超时时间，单位毫秒 (默认: 30000)
ORCHESTRATION_TIMEOUT=30000

# Token 使用预警阈值，0.9 表示达到 90% 时预警 (默认: 0.9)
ORCHESTRATION_TOKEN_THRESHOLD=0.9

# 工具执行超时时间，单位毫秒 (默认: 10000)
ORCHESTRATION_TOOL_TIMEOUT=10000

# 结果最大字符数，超出会被截断 (默认: 4000)
ORCHESTRATION_MAX_RESULT_LENGTH=4000

# ========== 可观测性配置 (Observability) ==========
# Langfuse 公钥
LANGFUSE_PUBLIC_KEY=your-langfuse-public-key

# Langfuse 密钥
LANGFUSE_SECRET_KEY=your-langfuse-secret-key

# Langfuse 服务地址 (默认: https://cloud.langfuse.com)
LANGFUSE_HOST=https://cloud.langfuse.com

# 是否启用可观测性 (默认: true，配置缺失时自动降级)
LANGFUSE_ENABLED=true